FRONT_PORT=5173

# ---------------------------------------------------------------------------
# Andromeda infrastructure (production)
# ---------------------------------------------------------------------------
# andromeda.andrescortes.dev  -> this app (OrbiX / virtual-store-app)
# admin.andromeda...          -> admin dashboard
# tickets.andromeda...        -> employee POS
# access.andromeda...         -> ticket verification
# service.andromeda...        -> ASP.NET API (use this for API calls)
# 204.168.212.239             -> VPS public IP (Postgres :5433, NOT the API host)
# ---------------------------------------------------------------------------

# Production on andromeda.andrescortes.dev (static files behind Ubuntu nginx):
# Call the API subdomain directly. Do NOT use the bare IP for API requests.
VITE_API_BASE_URL=https://service.andromeda.andrescortes.dev
VITE_MEDIA_BASE_URL=https://admin.andromeda.andrescortes.dev/storage

# Local dev: Vite proxies /api -> service (see vite.config.js). Uncomment for npm run dev:
# VITE_API_BASE_URL=/api

# Docker using this repo's nginx.conf (proxies /api to service). Uncomment for docker compose:
# VITE_API_BASE_URL=/api
